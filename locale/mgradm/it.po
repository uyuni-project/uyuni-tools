#: mgradm/cmd/support/sql/sql_cmd.go:26
msgid ""
"Execute SQL query either provided in sql-file or passed through standard input.\n"
"\n"
"Examples:\n"
"\n"
"  Run the 'select hostname from rhnserver;' query using echo:\n"
"\n"
"  # echo 'select hostname from rhnserver;' | mgradm support sql\n"
"\n"
"  Run in interative mode:\n"
"\n"
"  # mgradm support sql -i\n"
"\n"
"  Running the SQL queries in example.sql file and output them to out.log file\n"
"\n"
"  # mgradm support sql example.sql -o out.log\n"
"\n"
msgstr ""
"Eseguire la query SQL fornita nel file sql o passata tramite input standard.\n"
"\n"
"Esempi:\n"
"\n"
"  Eseguire la query 'select hostname from rhnserver;' utilizzando echo:\n"
"\n"
"  # echo 'seleziona il nome host da rhnserver;' | mgradm supporta sql\n"
"\n"
"  Esegui in modalità interattiva:\n"
"\n"
"  # mgradm supporta sql -i\n"
"\n"
"  Esecuzione delle query SQL nel file example.sql e loro output nel file out.log\n"
"\n"
"  # mgradm supporta sql example.sql -o out.log\n"
"\n"

