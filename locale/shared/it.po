#: shared/utils/config.go:116
msgid ""
"Usage:{{if .Runnable}}\n"
"  {{.UseLine}}{{end}}{{if .HasAvailableSubCommands}}\n"
"  {{.CommandPath}} [command]{{end}}{{if gt (len .Aliases) 0}}\n"
"\n"
"Aliases:\n"
"  {{.NameAndAliases}}{{end}}{{if .HasExample}}\n"
"\n"
"Examples:\n"
"{{.Example}}{{end}}{{if .HasAvailableSubCommands}}{{$cmds := .Commands}}{{if eq (len .Groups) 0}}\n"
"\n"
"Available Commands:{{range $cmds}}{{if (or .IsAvailableCommand (eq .Name \"help\"))}}\n"
"  {{rpad .Name .NamePadding }} {{.Short}}{{end}}{{end}}{{else}}{{range $group := .Groups}}\n"
"\n"
"{{.Title}}{{range $cmds}}{{if (and (eq .GroupID $group.ID) (or .IsAvailableCommand (eq .Name \"help\")))}}\n"
"  {{rpad .Name .NamePadding }} {{.Short}}{{end}}{{end}}{{end}}{{if not .AllChildCommandsHaveGroup}}\n"
"\n"
"Additional Commands:{{range $cmds}}{{if (and (eq .GroupID \"\") (or .IsAvailableCommand (eq .Name \"help\")))}}\n"
"  {{rpad .Name .NamePadding }} {{.Short}}{{end}}{{end}}{{end}}{{end}}{{end}}{{if .HasAvailableLocalFlags}}\n"
"\n"
"Flags:\n"
"{{.LocalFlags.FlagUsages | trimTrailingWhitespaces}}{{end}}{{if .HasAvailableInheritedFlags}}\n"
"\n"
"Global Flags:\n"
"{{.InheritedFlags.FlagUsages | trimTrailingWhitespaces}}{{end}}{{if .HasHelpSubCommands}}\n"
"\n"
"Additional help topics:{{range .Commands}}{{if .IsAdditionalHelpTopicCommand}}\n"
"  {{rpad .CommandPath .CommandPathPadding}} {{.Short}}{{end}}{{end}}{{end}}{{if .HasAvailableSubCommands}}\n"
"\n"
"Use \"{{.CommandPath}} [command] --help\" for more information about a command.{{end}}\n"
msgstr ""
"Utilizzo:{{se .Eseguibile}}\n"
"  {{.UseLine}}{{end}}{{if .Hasottocomandi disponibili}}\n"
"  {{.CommandPath}} [comando]{{fine}}{{se gt (len .Alias) 0}}\n"
"\n"
"Alias:\n"
"  {{.Nome e alias}}{{fine}}{{se .HasExample}}\n"
"\n"
"Esempi:\n"
"{{.Esempio}}{{fine}}{{se .Ha sottocomandi disponibili}}{{$cmds := .Comandi}}{{se eq (len .Gruppi) 0}}\n"
"\n"
"Comandi disponibili:{{range $cmds}}{{if (or .IsAvailableCommand (eq.Nome \"aiuto\"))}}\n"
"  {{rpad.Nome.NamePadding }} {{.Corto}}{{fine}}{{fine}}{{altro}}{{intervallo $gruppo:= .Gruppi}}\n"
"\n"
"{{.Titolo}}{{intervallo $cmds}}{{se (e (eq .GroupID $group.ID) (o .IsAvailableCommand (eq.Nome \"aiuto\")))}}\n"
"  {{rpad.Nome.NamePadding }} {{.Corto}}{{fine}}{{fine}}{{fine}}{{se non .Tutti i comandi per bambini hanno gruppo}}\n"
"\n"
"Comandi aggiuntivi:{{range $cmds}}{{if (and (eq .GroupID \"\") (o .IsAvailableCommand (eq.Nome \"aiuto\")))}}\n"
"  {{rpad.Nome.NamePadding }} {{.Corto}}{{fine}}{{fine}}{{fine}}{{fine}}{{fine}}{{se .Ha bandiere locali disponibili}}\n"
"\n"
"Bandiere:\n"
"{{.LocalFlags.FlagUsages | trimTrailingWhitespaces}}{{end}}{{if .HasAvailableInheritedFlags}}\n"
"\n"
"Bandiere globali:\n"
"{{.InheritedFlags.FlagUsages | trimTrailingWhitespaces}}{{end}}{{if .HasHelpSubCommands}}\n"
"\n"
"Argomenti di aiuto aggiuntivi:{{range .Comandi}}{{se .IsAdditionalHelpTopicCommand}}\n"
"  {{rpad.Percorso di comando.CommandPathPadding}} {{.Corto}}{{fine}}{{fine}}{{fine}}{{se .Hasottocomandi disponibili}}\n"
"\n"
"Utilizzare \"{{.CommandPath}} [comando] --help\" per maggiori informazioni su un comando.{{end}}\n"

#: shared/utils/config.go:150
msgid ""
"\n"
"Configuration:\n"
"\n"
"  All the non-global flags can alternatively be passed as configuration.\n"
"\n"
"  The configuration file is a YAML file with entries matching the flag name.\n"
"  The name of a flag is the part after the '--' of the command line parameter.\n"
"  Every '_' character in the flag name means a nested property.\n"
"\n"
"  For instance the '--tz CEST' and '--ssl-password secret' will be mapped to\n"
"  this YAML configuration:\n"
"\n"
"    tz: CEST\n"
"    ssl:\n"
"      password: secret\n"
"\n"
"  The configuration file will be searched in the following places and order:\n"
"  · /etc/uyuni/uyuni-tools.yaml\n"
"  · $XDG_CONFIG_HOME/{{ .Name }}/{{ .ConfigFile }}\n"
"  · $HOME/.config/{{ .Name }}/{{ .ConfigFile }}\n"
"  · $PWD/{{ .ConfigFile }}\n"
"  · the value of the --config flag\n"
"\n"
"\n"
"Environment variables:\n"
"\n"
"  All the non-global flags can also be passed as environment variables.\n"
"\n"
"  The environment variable name is the flag name with '-' replaced by with '_'\n"
"  and the {{ .EnvPrefix }} prefix.\n"
"\n"
"  For example the '--tz CEST' flag will be mapped to '{{ .EnvPrefix }}_TZ'\n"
"  and '--ssl-password' flags to '{{ .EnvPrefix }}_SSL_PASSWORD'\n"
msgstr ""
"\n"
"Configurazione:\n"
"\n"
"  In alternativa, tutti i flag non globali possono essere passati come configurazione.\n"
"\n"
"  Il file di configurazione è un file YAML con voci corrispondenti al nome del flag.\n"
"  Il nome di un flag è la parte dopo '--' del parametro della riga di comando.\n"
"  Ogni carattere '_' nel nome del flag indica una proprietà annidata.\n"
"\n"
"  Ad esempio, '--tz CEST' e '--ssl-password secret' verranno mappati su\n"
"  questa configurazione YAML:\n"
"\n"
"    tz: CEST\n"
"    ssl:\n"
"      password: segreta\n"
"\n"
"  La ricerca nel file di configurazione avverrà nei seguenti punti e nel seguente ordine:\n"
"  · /etc/uyuni/uyuni-tools.yaml\n"
"  · $XDG_CONFIG_HOME/{{ .Nome }}/{{ .ConfigFile }}\n"
"  · $HOME/.config/{{ .Nome }}/{{ .ConfigFile }}\n"
"  · $PWD/{{ .ConfigFile }}\n"
"  · il valore del flag --config\n"
"\n"
"\n"
"Variabili ambientali:\n"
"\n"
"  Tutti i flag non globali possono anche essere passati come variabili d'ambiente.\n"
"\n"
"  Il nome della variabile d'ambiente è il nome del flag con '-' sostituito da '_'\n"
"  e il {{ .Prefisso EnvPrefix }}.\n"
"\n"
"  Ad esempio il flag '--tz CEST' verrà mappato su '{{ .EnvPrefix }}_TZ'\n"
"  e i flag '--ssl-password' a '{{ .EnvPrefix }}_SSL_PASSWORD'\n"

